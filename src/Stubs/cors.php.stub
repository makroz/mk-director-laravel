<?php

declare(strict_types=1);

/*
 * CORS config scaffoldeado por `mk:make:auth-user` (R-PKG-042 FASE18-07).
 *
 * **Por quĂ© este archivo existe**: cada consumer de `makroz/director-laravel`
 * que sirve una SPA (Next.js, React, Vue) necesita CORS allow-list para
 * los endpoints `/api/*`. Pre-R-PKG-042 el scaffolder NO lo pineaba, asĂ­
 * que cada consumer tenĂ­a que crearlo a mano (y muchos olvidaban â€” RETO
 * fase 18 fue un caso real, HALLAZGO-NEW-FASE18-07).
 *
 * **QuĂ© hace este archivo**:
 *   - `paths`: `['api/*']` cubre todos los endpoints del paquete.
 *     Si usĂˇs Sanctum SPA flow (cookie-based), sumĂˇ `'sanctum/csrf-cookie'`.
 *   - `allowed_origins`: lee desde `config('mk_director.frontend.frontend_origins')`
 *     (que a su vez lee de `FRONTEND_ORIGINS` env var). Default dev-friendly
 *     para `localhost:3000` y `127.0.0.1:3000` (Next.js dev server).
 *   - `supports_credentials`: `true` para Sanctum SPA. Si NO usĂˇs cookies,
 *     setear `false` y `allowed_headers` no necesita `Authorization`.
 *   - `allowed_methods` / `allowed_headers`: explĂ­citos (no `*`) para
 *     evitar CORS error silencioso en algunos browsers cuando se usa
 *     `Authorization` header con credentials.
 *
 * **Override**:
 *   - Env var: `FRONTEND_ORIGINS=https://admin.example.com,https://app.example.com`
 *     (comma-separated, sin espacios) para prod.
 *   - Publicar el config: `php artisan vendor:publish --tag=mk-director-cors`
 *     y editar `config/cors.php` directamente.
 *   - Granular override: agregar paths especĂ­ficos, methods, headers en
 *     este mismo archivo (Laravel CORS permite `allowed_origins_patterns`
 *     para wildcards, `exposed_headers` para que el browser exponga headers
 *     custom al JS, etc.).
 *
 * **R-PKG-042 carry-over**: si el scaffolder pineĂł este archivo y querĂ©s
 * reset a package default, borrĂˇ el archivo y re-ejecutĂˇ `mk:make:auth-user`
 * con `--force-cors` (prĂłximo sprint, backlog).
 */

return [
    /*
    | Paths allow-list. `api/*` cubre todos los endpoints del paquete.
    | SumĂˇ `'sanctum/csrf-cookie'` si usĂˇs Sanctum SPA flow.
    | SumĂˇ `'livewire/*'` si usĂˇs Livewire (no aplica al paquete).
    */
    'paths' => array_merge(
        config('mk_director.frontend.paths', ['api/*']),
        {{extraCorsPaths}}
    ),

    /*
    | Allowed request methods. Default RESTful + preflight.
    */
    'allowed_methods' => ['*'],

    /*
    | Allowed origins. Lee del env var `FRONTEND_ORIGINS` (comma-separated)
    | o del default en `config/mk_director.php`. Si necesitĂˇs wildcards
    | (e.g. `https://*.example.com`), usĂˇ `allowed_origins_patterns` abajo.
    */
    'allowed_origins' => config('mk_director.frontend.frontend_origins', [
        'http://localhost:3000',
        'http://127.0.0.1:3000',
    ]),

    /*
    | Wildcard origins (e.g. `https://*.example.com` para subdominios
    | dinĂˇmicos). Dejar vacĂ­o si no se necesita.
    */
    'allowed_origins_patterns' => [],

    /*
    | Allowed request headers. Por defecto todos (`*`).
    | Si `supports_credentials` es `true`, NO se puede usar `*` para
    | `allowed_headers` en algunos browsers â€” explĂ­cito es mĂˇs seguro.
    */
    'allowed_headers' => ['*'],

    /*
    | Exposed headers â€” los que el browser expone al JS. Ăštil si tu SPA
    | lee headers custom del response (e.g. `X-Request-Id`, `X-RateLimit-Remaining`).
    */
    'exposed_headers' => [],

    /*
    | Max age (en segundos) del preflight cache. Default 1 dĂ­a.
    | Si tu API cambia CORS config seguido, bajĂˇ a 0 (no cache).
    */
    'max_age' => 86400,

    /*
    | `supports_credentials` indica si el browser puede enviar credentials
    | (cookies, Authorization header). Para Sanctum SPA flow con cookies,
    | necesita `true`. Si usĂˇs solo Bearer tokens (no cookies), podĂ©s
    | setear `false` y la config es mĂˇs permisiva.
    */
    'supports_credentials' => (bool) config('mk_director.frontend.supports_credentials', true),
];
