# ────────────────────────────────────────────────────────────────────────────
# MK-Director (`makroz/director-laravel`) — environment variables reference.
# ────────────────────────────────────────────────────────────────────────────
#
# Todas estas vars son OPCIONALES — el paquete tiene defaults dev-friendly.
# Si NO pineás ninguna, tu app bootea con los defaults listados en
# `config/mk_director.php`. Esta file existe solo para documentar QUÉ
# podés overridear sin tener que abrir el config PHP.
#
# Cómo usar: copiá este archivo a `.env` del consumer
# (`cp .env.example .env`) y descomentá solo las vars que querés
# overridear para tu ambiente (dev/staging/prod).

# ────────────────────────────────────────────────────────────────────────────
# Frontend CORS (HALLAZGO-NEW-FASE19-03 — pineado en R-PKG-043)
# ────────────────────────────────────────────────────────────────────────────
#
# El `config/cors.php` scaffoldeado por `mk:make:auth-user` lee los
# `allowed_origins` desde `mk_director.frontend.frontend_origins`, que a
# su vez lee de esta env var. Defaults dev-friendly en
# `config/mk_director.php` (http://localhost:3000 + http://127.0.0.1:3000
# para Next.js dev). Override en prod con tu dominio real.
#
# Formato: comma-separated, sin espacios alrededor de las comas.
# Wildcards: NO soportados directamente — usá `allowed_origins_patterns`
# editando `config/cors.php` directamente.
#
# Default: 'http://localhost:3000,http://127.0.0.1:3000'
#FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#FRONTEND_ORIGINS=https://admin.example.com,https://app.example.com

# Si usás Sanctum SPA flow (cookie-based auth), necesita `true`. Si NO usás
# cookies (Bearer-only), podés `false` y el `allowed_headers` se relaja.
#
# Default: true
#FRONTEND_SUPPORTS_CREDENTIALS=true

# ────────────────────────────────────────────────────────────────────────────
# Auth / Sanctum (R-PKG-031 R-PKG-034)
# ────────────────────────────────────────────────────────────────────────────
#
# Modelo del user default del paquete (cualquier `AuthUser` subclass).
# Cada scope (admin, member) puede overridear con su propia configuración
# en `config/auth.php` — esto es solo el default global.
#
# Default: no pineado → usa el del `config/auth.php` del consumer
#MK_AUTH_USER_MODEL=App\\Models\\User

# Login field default del paquete. Override por scope via
# `mk:make:auth-user X --login-field=<campo>` (e.g. ci, phone, username).
#
# Default: email
#MK_LOGIN_FIELD=email

# Auto-discover abilities al boot. RIESGO: si tu `CACHE_STORE` no soporta
# tags, el primer request CRUD revienta. Para dev/testing, dejá `false`
# y corré `php artisan mk:discover-abilities` explícitamente cuando
# agregues abilities nuevas.
#
# Default: false (en .env.example del consumer — el paquete NO pinea default)
#MK_AUTO_DISCOVER_ABILITIES=false

# Habilita análisis IA opcional via `mk-ai` Artisan commands.
#
# Default: false
#MK_AI_ANALYSIS=false

# ────────────────────────────────────────────────────────────────────────────
# Auth rate limiting (R-PKG-035 + R-PKG-041 — `--with-auth-rbac`)
# ────────────────────────────────────────────────────────────────────────────
#
# Rate limits (req/min) para endpoints públicos del auth flow. Solo aplica
# cuando el scope se scaffoldea con `--with-auth-rbac`. Si no, los rate
# limits se pinean sin efecto (no hay middleware throttle).
#
# Default: 5 (login/forgot/reset), 30 (refresh/me/logout si pinea throttle)
#MK_AUTH_RATE_LIMIT_LOGIN=5
#MK_AUTH_RATE_LIMIT_FORGOT=5
#MK_AUTH_RATE_LIMIT_RESET=5

# ────────────────────────────────────────────────────────────────────────────
# Cache (PKG-NEW-14 — driver check)
# ────────────────────────────────────────────────────────────────────────────
#
# SmartController / CRUDSmart / CacheTrait usan `Cache::tags()`
# extensivamente. Los drivers SIN tag support (file/database/array/null)
# revientan con `RuntimeException: cache driver does not support tags`.
#
# Drivers production-ready CON tag support: redis, memcached.
# Para dev/testing: `array` + `MK_CACHE_ALLOW_FULL_CLEAR=true`.
#
# Default Laravel: file (no tags → falla!)
#MK_CACHE_STORE=redis
#MK_CACHE_ALLOW_FULL_CLEAR=true
#MK_CACHE_TTL=3600

# ────────────────────────────────────────────────────────────────────────────
# Multi-tenant (R-PKG-014 MkMultiTenantPlugin — opt-in)
# ────────────────────────────────────────────────────────────────────────────
#
# Habilita el plugin multi-tenant del paquete. `false` por default
# (consumers que no necesitan multi-tenant no pinean esto).
#
# Default: false
#MK_TENANT_ENABLED=false

# Cómo resolver el tenant_id del request: 'header' (X-Tenant-ID header) o
# 'domain' (subdomain matching). Solo aplica si MK_TENANT_ENABLED=true.
#
# Default: header
#MK_TENANT_RESOLVER=header

# Header HTTP que lleva el tenant_id. Cambialo si tu frontend usa otro
# nombre (e.g. algunos usan `X-Org-Id` o `X-Workspace-Id`).
#
# Default: X-Tenant-ID
#MK_TENANT_HEADER=X-Tenant-ID

# Modelo Eloquent del tenant. Si no se pinea, el plugin no resuelve
# instancias de Tenant (solo el FK client_id genérico).
#
# Default: null
#MK_TENANT_MODEL=App\\Models\\Tenant

# Si `true`, queries sin tenant_id pineado fallan con excepción (fail-safe
# para data leaks). `false` permite queries sin scope (dev convenience).
#
# Default: true
#MK_TENANT_STRICT=true

# ────────────────────────────────────────────────────────────────────────────
# Module loader (R-PKG-014 `mk:module` scaffolder)
# ────────────────────────────────────────────────────────────────────────────
#
# Path donde `php artisan mk:module X` scaffoldea nuevos módulos.
# Default `app/Modules` (canónico DDD modular). Solo overrideá si tenés
# convención custom.
#
# Default: app/Modules
#MK_MODULES_PATH=app/Modules

# ────────────────────────────────────────────────────────────────────────────
# List / Pagination behavior
# ────────────────────────────────────────────────────────────────────────────
#
# Tipo de paginator default: 'length' (LengthAwarePaginator) o 'cursor'
# (CursorPaginator). Override por endpoint via `BaseController::paginate()`.
#
# Default: length
#MK_PAGINATION_TYPE=length

# Per-page default del `useMkList` y equivalente Laravel. Si querés un
# default distinto de 20 (e.g. tablas grandes → 50), pinear acá.
#
# Default: 20
#MK_LIST_DEFAULT_PER_PAGE=20

# Tope máximo (defense-in-depth contra `?per_page=999999`).
#
# Default: 100
#MK_LIST_MAX_PER_PAGE=100

# Min chars antes de que `useMkList` dispare search query. Anti-DoS.
#
# Default: 2
#MK_SEARCH_MIN_CHARS=2

# ────────────────────────────────────────────────────────────────────────────
# Debugging / Diagnostics (HALLAZGO-NEW-FASE14 — `mk:status`)
# ────────────────────────────────────────────────────────────────────────────
#
# Habilita debug output en BaseController responses (envelope incluye
# timing + memory + query count). NUNCA pinees `true` en producción
# (leak de internals).
#
# Default: false
#MK_DIRECTOR_DEBUG=false

# Habilita la salida de `mk:status --explain` con detalle de qué
# lints pasaron / fallaron. Útil en CI logs.
#
# Default: false
#MK_DIRECTOR_DEBUG_EXPLAIN_ENABLED=false

# ────────────────────────────────────────────────────────────────────────────
# File uploads (R-PKG-022 MkFileUploadPlugin)
# ────────────────────────────────────────────────────────────────────────────
#
# Genera variantes WebP automáticas para imágenes subidas (ahorra bandwidth
# en Next.js Image / responsive img).
#
# Default: true
#MK_FILE_WEBP=true

# ────────────────────────────────────────────────────────────────────────────
# Cross-cutting feature flags
# ────────────────────────────────────────────────────────────────────────────
#
# Habilita auto-cache en queries de lectura (read-through cache via
# `Cache::tags()`). Útil en producción, NO en dev (cache stale complica
# iteration). Defense-in-depth: requiere `CACHE_STORE` con tag support.
#
# Default: false
#MK_AUTO_CACHE=false

# Habilita `?include=` dinámico en endpoints (eager-load relations on demand).
# BC-safe vs API fija. Default true (canónico Laravel API resources).
#
# Default: true
#MK_DYNAMIC_INCLUDES=true

# Habilita JOINs dinámicos para sort columns (anti-N+1). Performance trade-off.
#
# Default: true
#MK_DYNAMIC_JOINS=true

# Habilita filtros query-string (`?filter[admin.admins.view]=1`).
#
# Default: true
#MK_FILTERS=true

# Habilita full-text search en modelos. Requiere `MK_SEARCH=true` + índice
# configurado en cada modelo via `Searchable` trait.
#
# Default: false
#MK_SEARCH=false

# Guarda el "remember me" state en cookie (Sanctum remember token).
#
# Default: true
#MK_REMEMBER_STATE=true

# Tabla donde se persisten los códigos progresivos (auth flow con MFA).
# Si no usás MFA, dejá pineado para evitar errores en runtime checks.
#
# Default: progressive_codes
#MK_PROGRESSIVE_CODES_TABLE=progressive_codes
